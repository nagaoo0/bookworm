# Copy to .env and fill in values
POSTGRES_DB=bookworm
POSTGRES_USER=bookworm
POSTGRES_PASSWORD=changeme

# Optional — without a key, Google Books API works at reduced quota
GOOGLE_BOOKS_API_KEY=
RECAPTCHA_SITE_KEY=your_site_key_here
RECAPTCHA_SECRET=your_secret_key_here
RECAPTCHA_MIN_SCORE=0.5

# Ports on the host
API_PORT=3000
FRONTEND_PORT=8080

# Used by the frontend nginx to proxy /api → api container
VITE_API_BASE=/api

# Set to "production" to enable secure cookies and strict CORS
NODE_ENV=development

# Comma-separated list of allowed frontend origins — REQUIRED in production
# Example: ALLOWED_ORIGINS=https://books.yourdomain.com
ALLOWED_ORIGINS=http://localhost:8080

# Number of reverse-proxy hops to trust for X-Forwarded-For (default: 1).
# Set to "false" if the API is exposed directly with no proxy in front.
TRUST_PROXY=1
